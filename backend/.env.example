# Copy this to .env and fill in real values
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/abhimart
DEBUG=true

# LangGraph checkpoint database. For local dev this can point at the same
# Postgres instance as DATABASE_URL, but using the non-SQLAlchemy URL format.
CHECKPOINT_DATABASE_URL=postgresql://user:password@localhost:5432/abhimart

# AI / tracing keys
GEMINI_API_KEY=your-gemini-api-key
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=abhimart
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
